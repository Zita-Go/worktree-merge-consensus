{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "fixtureVersion": "minimum-0.144.1",
  "protocolFamily": "codex-app-server/experimental-v2",
  "minimumVersion": "0.144.1",
  "requiredMethods": [
    "initialize",
    "thread/list",
    "thread/read",
    "thread/resume",
    "turn/start",
    "turn/interrupt",
    "command/exec",
    "config/read",
    "config/batchWrite",
    "mcpServerStatus/list"
  ],
  "requiredNotifications": [
    "thread/status/changed",
    "turn/started",
    "item/started",
    "item/completed",
    "turn/completed"
  ],
  "requestShape": {
    "initialize": ["clientInfo", "capabilities"],
    "thread/list": [],
    "thread/read": ["threadId", "includeTurns"],
    "thread/resume": {
      "default": ["threadId"],
      "primaryIntegration": ["threadId", "config"]
    },
    "turn/start": [
      "threadId",
      "input",
      "cwd",
      "runtimeWorkspaceRoots",
      "approvalPolicy",
      "approvalsReviewer",
      "environments",
      "sandboxPolicy"
    ],
    "turn/interrupt": ["threadId", "turnId"],
    "command/exec": [
      "command",
      "cwd",
      "timeoutMs",
      "outputBytesCap",
      "sandboxPolicy"
    ],
    "config/read": ["includeLayers"],
    "config/batchWrite": ["edits", "reloadUserConfig"],
    "mcpServerStatus/list": ["threadId", "detail"]
  },
  "initializeCapabilities": {
    "experimentalApi": true
  },
  "turnEnvironmentSelection": {
    "environmentId": "local",
    "cwdRole": "turnCwd",
    "inheritStickyEnvironment": false
  },
  "turnLifecycle": {
    "requiredBeforeEveryTurnStart": ["thread/resume"]
  },
  "responseValidation": {
    "transportOutputSchema": false,
    "localProtocolSchema": "../protocol-v1.json",
    "participantResponseProtocol": "worktree-merge-consensus/v2",
    "failClosed": true
  },
  "initializeResponseShape": [
    "codexHome",
    "platformFamily",
    "platformOs",
    "userAgent"
  ],
  "turnPolicyShape": {
    "dangerFullAccess": ["type"]
  },
  "turnPolicyProfiles": {
    "review": {
      "approvalPolicy": "never",
      "sandboxPolicy": {
        "type": "dangerFullAccess"
      }
    },
    "primaryIntegration": {
      "approvalPolicy": "never",
      "sandboxPolicy": {
        "type": "dangerFullAccess"
      }
    },
    "primaryVerification": {
      "approvalPolicy": "never",
      "sandboxPolicy": {
        "type": "dangerFullAccess"
      }
    }
  },
  "commandExecutionEvidenceShape": {
    "required": ["id", "type", "command", "cwd", "status", "exitCode"],
    "type": "commandExecution",
    "successfulStatus": "completed",
    "successfulExitCode": 0,
    "agentSourceWhenPresent": "agent",
    "primarySource": "persisted item lifecycle through turn/completed",
    "historicalFallback": "thread/read full turn items"
  }
}
